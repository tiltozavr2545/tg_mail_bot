# ===== Telegram =====
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Твой Telegram chat_id (узнать можно у @userinfobot). Бот шлёт выжимки только сюда.
TELEGRAM_CHAT_ID=123456789

# ===== Gmail (IMAP, App Password) =====
# Адрес твоего Gmail
GMAIL_ADDRESS=you@gmail.com
# Пароль приложения (16 символов), НЕ обычный пароль от аккаунта.
# Создать: https://myaccount.google.com/apppasswords (нужен включённый 2FA)
GMAIL_APP_PASSWORD=abcdefghijklmnop
# IMAP-хост Gmail (обычно менять не нужно)
IMAP_HOST=imap.gmail.com

# ===== Gemini =====
# API-ключ из Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
# Модель
GEMINI_MODEL=gemini-2.5-flash

# ===== Поведение =====
# Как часто проверять почту, в секундах
POLL_INTERVAL_SECONDS=60
# Язык выжимки (на каком языке писать саммари)
SUMMARY_LANGUAGE=русском

# ===== Персонализация =====
# ФИО владельца почты. Бот выделяет всё, что относится лично к нему,
# и в списках/таблицах баллов находит именно его строку.
OWNER_NAME=Фамилия Имя Отчество
# Доп. контекст о владельце (необязательно), напр. группа, что важно отслеживать.
OWNER_CONTEXT=
# Люди, чьи результаты вытаскивать из таблиц баллов (через запятую).
TRACKED_PEOPLE=Фамилия Имя, Другая Фамилия Имя
